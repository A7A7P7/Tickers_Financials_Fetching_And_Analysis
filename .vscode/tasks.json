{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "📦 Install dependencies",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/python.exe",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "windows": {
        "command": "${workspaceFolder}\\venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/venv/bin/python"
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 Launch dashboard (Streamlit)",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/python.exe",
      "args": ["-m", "streamlit", "run", "app.py"],
      "windows": {
        "command": "${workspaceFolder}\\venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/venv/bin/python"
      },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
