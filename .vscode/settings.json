{
  // ─── Python interpreter ────────────────────────────────────────────────
  // Default: use the local virtual environment created by setup.sh/setup.ps1.
  // Windows path uses forward slashes (VSCode handles both).
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/Scripts/python.exe",
  "python.envFile": "${workspaceFolder}/.env",
  // ─── Terminal ──────────────────────────────────────────────────────────
  // Auto-activate the venv in every new integrated terminal.
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,

  // ─── Analysis ──────────────────────────────────────────────────────────
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.extraPaths": ["${workspaceFolder}"],

  // ─── Jupyter (the .py files use #%% interactive cells) ────────────────
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "jupyter.interactiveWindow.creationMode": "perFile",

  // ─── Editor ────────────────────────────────────────────────────────────
  "editor.formatOnSave": false,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "[python]": {
    "editor.rulers": [100],
    "editor.tabSize": 4
  },
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda"
}


